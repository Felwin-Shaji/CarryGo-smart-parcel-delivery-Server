# Application
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/carrygo

# Authentication
SALT_ROUNDS=10
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-secret
# Cookie lifetime in milliseconds
ACCESS_TOKEN_MAX_AGE=1800000
REFRESH_TOKEN_MAX_AGE=604800000

# Email (Gmail app password recommended)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Google authentication
CLIENT_ID=your-google-client-id.apps.googleusercontent.com
CLIENT_SECRET=your-google-client-secret
REDIRECT_URI=http://localhost:5000/api/auth/google/callback
REFRESH_TOKEN=your-google-oauth-refresh-token

# Cloudinary
CLOUD_NAME=your-cloudinary-cloud-name
CLOUD_API_KEY=your-cloudinary-api-key
CLOUD_API_SECRET=your-cloudinary-api-secret

# Geocoding
GEOCODING_SECRET_API_KEY=your-geocoding-api-key

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
RAZORPAYX_ACCOUNT_NUMBER=your-razorpayx-account-number
